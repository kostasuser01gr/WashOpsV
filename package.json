    "@radix-ui/react-toast": "*",
    "@tanstack/react-table": "*",
    "@vercel/blob": "*",
    "@vercel/kv": "*",
    "clsx": "*",
    "cmdk": "*",
    "dexie": "*",
    "framer-motion": "*",
    "lucide-react": "*",
    "nanoid": "*",
    "next": "*",
    "next-auth": "*",
    "react": "*",
    "react-dom": "*",
    "recharts": "*",
    "zod": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "*",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/lodash": "*",
    "@types/node": "*",
    "@types/react": "*",
