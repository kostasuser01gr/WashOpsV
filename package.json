    "eslint-plugin-react-refresh": "^0.4.22",
    "husky": "^8.0.0",
    "lint-staged": "*",
    "playwright": "*",
    "postcss": "*",
    "prettier": "*",
    "prisma": "*",
    "tailwindcss": "*",
    "tsx": "*",
    "typescript": "*",
    "typescript-eslint": "^8.44.1",
    "vitest": "*"
